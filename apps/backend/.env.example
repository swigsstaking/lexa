# Lexa Backend — .env.example
# Copier en .env et remplir les valeurs réelles (ne JAMAIS commit .env)

# Server
NODE_ENV=development
PORT=3010
LOG_LEVEL=info

# Postgres (event store)
DATABASE_URL=postgresql://lexa_app:PASSWORD@localhost:5432/lexa
# Ou équivalent:
# PGHOST=localhost
# PGPORT=5432
# PGUSER=lexa_app
# PGPASSWORD=xxx
# PGDATABASE=lexa

# DGX Spark (AI endpoints)
SPARK_HOST=192.168.110.103
OLLAMA_URL=http://192.168.110.103:11434
QDRANT_URL=http://192.168.110.103:6333
EMBEDDER_URL=http://192.168.110.103:8082

# Ollama models
MODEL_CLASSIFIER=qwen3.5:27b-q8_0
MODEL_REASONING=comptable-suisse
MODEL_OCR=qwen3-vl-ocr

# Qdrant
QDRANT_COLLECTION=swiss_law
RAG_TOP_K=5

# vLLM (Qwen3.5-35B-A3B-NVFP4 sur DGX Spark — ~4-5× plus rapide que Ollama natif)
# URL du serveur vLLM (OpenAI-compat)
VLLM_URL=http://192.168.110.103:8100

# Classifier — déjà en prod
USE_VLLM_CLASSIFIER=false
VLLM_CLASSIFIER_MODEL=apolo13x/Qwen3.5-35B-A3B-NVFP4

# Audit — activer après test (latence actuelle ~68s p95, vLLM vise <20s)
# Passer à true manuellement après validation
USE_VLLM_AUDIT=false
VLLM_AUDIT_MODEL=apolo13x/Qwen3.5-35B-A3B-NVFP4

# Reasoning (ragQuery) — activer après test (latence actuelle ~43s p95, vLLM vise <12s)
# Passer à true manuellement après validation
USE_VLLM_REASONING=false
VLLM_REASONING_MODEL=apolo13x/Qwen3.5-35B-A3B-NVFP4

# Modèle vLLM partagé pour les 12 agents migrés (surcharge possible par agent si besoin)
VLLM_MODEL=apolo13x/Qwen3.5-35B-A3B-NVFP4

# Agents migrés vLLM — activer un par un après validation qualité
# Tous à false par défaut, l'instance mère active en prod après bench
USE_VLLM_LEXA=false
USE_VLLM_TVA=false
USE_VLLM_CLOTURE=false
USE_VLLM_CONSEILLER=false
USE_VLLM_FISCAL_PP_VS=false
USE_VLLM_FISCAL_PP_GE=false
USE_VLLM_FISCAL_PP_VD=false
USE_VLLM_FISCAL_PP_FR=false
USE_VLLM_FISCAL_PP_NE=false
USE_VLLM_FISCAL_PP_JU=false
USE_VLLM_FISCAL_PP_BJ=false
USE_VLLM_FISCAL_PM=false

# Crypto module — PP wallets + snapshots annuels (V1.3)
# NE JAMAIS commit de vraie clé ici — mettre les vraies clés dans .env.production sur .59 uniquement
CMC_API_KEY=                # CoinMarketCap key (récupérer sur pro-api.coinmarketcap.com)
ETHERSCAN_API_KEY=          # Etherscan free tier key (etherscan.io/apis)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
