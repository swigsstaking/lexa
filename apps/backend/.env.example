# Lexa Backend — .env.example
# Copier en .env et remplir les valeurs réelles (ne JAMAIS commit .env)

# Server
NODE_ENV=development
PORT=3010
LOG_LEVEL=info

# Postgres (event store)
DATABASE_URL=postgresql://lexa_app:PASSWORD@localhost:5432/lexa
# Ou équivalent:
# PGHOST=localhost
# PGPORT=5432
# PGUSER=lexa_app
# PGPASSWORD=xxx
# PGDATABASE=lexa

# DGX Spark (AI endpoints)
SPARK_HOST=192.168.110.103
OLLAMA_URL=http://192.168.110.103:11434
QDRANT_URL=http://192.168.110.103:6333
EMBEDDER_URL=http://192.168.110.103:8001

# Ollama models
MODEL_CLASSIFIER=qwen3.5:27b-q8_0
MODEL_REASONING=comptable-suisse
MODEL_OCR=qwen3-vl-ocr

# Qdrant
QDRANT_COLLECTION=swiss_law
RAG_TOP_K=5
